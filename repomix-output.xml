                        </span>
                      </td>
                      <td className="px-6 py-4 text-sm text-gray-400">{s.averageTimePerQuestion} sec</td>
                      <td className="px-6 py-4 text-sm text-gray-400">
                        {/* 🎯 NAYA LOGIC: Yahan hum state mein subjectName aur examName bhej rahe hain */}
